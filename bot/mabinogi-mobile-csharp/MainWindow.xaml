<Window x:Class="MabinogiMacro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mabinogi Mobile Macro" Width="500" Height="600"
        WindowStartupLocation="CenterScreen" Closed="Window_Closed">

    <Window.InputBindings>
        <KeyBinding Gesture="Escape" Command="{x:Static ApplicationCommands.Stop}"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Stop}" Executed="StopCommand_Executed"/>
    </Window.CommandBindings>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Mabinogi Mobile Macro (C# .NET 8)"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
            <Button Name="BtnStart" Content="Start" Click="BtnStart_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Name="BtnStop" Content="Stop" Click="BtnStop_Click" Background="#F44336" Foreground="White" FontWeight="Bold" IsEnabled="False"/>
            <Button Name="BtnTest" Content="Test Input" Click="BtnTest_Click"/>
            <Button Name="BtnReload" Content="Reload Config" Click="BtnReload_Click"/>
        </StackPanel>

        <!-- Settings -->
        <GroupBox Grid.Row="2" Header="Settings" Margin="0,0,0,4" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Input Method:" VerticalAlignment="Center"/>
                <ComboBox Name="CmbInputMethod" Grid.Row="0" Grid.Column="1" SelectedIndex="1" Margin="0,2">
                    <ComboBoxItem Content="SendInput (Foreground)"/>
                    <ComboBoxItem Content="PostMessage (Background)" IsSelected="True"/>
                    <ComboBoxItem Content="SendMessage (Background Sync)"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Tick Interval (s):" VerticalAlignment="Center"/>
                <TextBox Name="TxtTickInterval" Grid.Row="1" Grid.Column="1" Text="0.5" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Window Title:" VerticalAlignment="Center"/>
                <TextBox Name="TxtWindowTitle" Grid.Row="2" Grid.Column="1" Text="Mabinogi Mobile" Margin="0,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Confidence:" VerticalAlignment="Center"/>
                <TextBox Name="TxtConfidence" Grid.Row="3" Grid.Column="1" Text="0.5" Margin="0,2"/>
            </Grid>
        </GroupBox>

        <!-- Log Output -->
        <GroupBox Grid.Row="3" Header="Log" Margin="0,0,0,4">
            <TextBox Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap"
                     FontFamily="Consolas" FontSize="11" Background="#1E1E1E" Foreground="#D4D4D4"/>
        </GroupBox>

        <!-- Status -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Status:" FontWeight="Bold"/>
            <TextBlock Name="TxtStatus" Grid.Column="1" Text="Idle"/>
        </Grid>

        <!-- Stats -->
        <Expander Grid.Row="5" Header="Statistics">
            <TextBlock Name="TxtStats" Text="No stats yet." FontFamily="Consolas"/>
        </Expander>
    </Grid>
</Window>
