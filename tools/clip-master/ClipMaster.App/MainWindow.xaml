<Window x:Class="ClipMaster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ClipMaster - Automated Batch Editor" Height="600" Width="900"
        Background="#F4F4F9" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#2D2D30" Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ClipMaster" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="Automated Video Batch Editor" Foreground="#9E9E9E" FontSize="14" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content (Tabs) -->
        <TabControl Grid.Row="1" Margin="10" Background="Transparent" BorderThickness="0">
            <TabItem Header="Video-Audio Merge" Padding="15,5">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Input Videos" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ListBox x:Name="VideoList" Height="150" Margin="0,0,0,5" Background="White" BorderBrush="#DDD"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Clear" Width="80" Margin="5" Click="ClearVideos_Click"/>
                            <Button Content="Add Videos" Width="100" Margin="5" Background="#007ACC" Foreground="White" Click="AddVideos_Click"/>
                        </StackPanel>

                        <TextBlock Text="Background Music" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AudioPathTxt" Margin="0,0,5,0" Padding="5" IsReadOnly="True" Background="#EEE"/>
                            <Button Grid.Column="1" Content="Select Music" Width="100" Click="SelectAudio_Click"/>
                        </Grid>

                        <TextBlock Text="Output Directory" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputPathTxt" Margin="0,0,5,0" Padding="5" IsReadOnly="True" Background="#EEE"/>
                            <Button Grid.Column="1" Content="Browse" Width="100" Click="BrowseOutput_Click"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Options" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        
                        <Label Content="Audio Volume (0.0 - 2.0)"/>
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="2" Value="1.0" Margin="0,0,0,10" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ElementName=VolumeSlider, Path=Value, StringFormat={}{0:F1}}" HorizontalAlignment="Right"/>

                        <Label Content="Fade In (seconds)"/>
                        <TextBox x:Name="FadeInTxt" Text="0" Margin="0,0,0,10" Padding="5"/>

                        <Label Content="Fade Out (seconds)"/>
                        <TextBox x:Name="FadeOutTxt" Text="0" Margin="0,0,0,10" Padding="5"/>

                        <Label Content="Output File Suffix"/>
                        <TextBox x:Name="SuffixTxt" Text="merged" Margin="0,0,0,10" Padding="5"/>

                        <Separator Margin="0,20"/>
                        
                        <Button Content="START BATCH PROCESSING" Height="50" FontWeight="Bold" Background="#007ACC" Foreground="White" Click="StartBatch_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <TabItem Header="Batch Conversion" Padding="15,5">
                <Grid Margin="10">
                    <TextBlock Text="Coming Soon: Video Format Conversion, Resolution Scaling, etc." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="#666"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer / Progress -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="GlobalProgressBar" Height="20" Margin="0,0,10,0"/>
                <TextBlock x:Name="StatusTxt" Grid.Column="1" Text="Ready" Foreground="White" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
