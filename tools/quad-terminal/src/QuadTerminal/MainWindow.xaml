<Window x:Class="QuadTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:QuadTerminal.Controls"
        Title="QuadTerminal"
        Height="600" Width="1000"
        Background="#1e1e1e"
        WindowState="Maximized"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Border" x:Key="PaneHeaderBorder">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PaneHeaderText">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2d2d2d" Padding="6,3" BorderBrush="#3d3d3d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#9638; QuadTerminal" Foreground="#007ACC" FontSize="13"
                           FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,6,2"/>
                <Button Content="1x1" Style="{StaticResource ToolBarButton}" Click="LayoutSingle_Click" ToolTip="Single pane"/>
                <Button Content="2x1" Style="{StaticResource ToolBarButton}" Click="LayoutDualH_Click" ToolTip="Two panes horizontal"/>
                <Button Content="1x2" Style="{StaticResource ToolBarButton}" Click="LayoutDualV_Click" ToolTip="Two panes vertical"/>
                <Button Content="2x2" Style="{StaticResource ToolBarButton}" Click="LayoutQuad_Click" ToolTip="Four panes (Q-Dir style)"/>
            </StackPanel>
        </Border>

        <Grid x:Name="TerminalGrid" Grid.Row="1" Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightCol" Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="BottomRow" Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="Pane0Container" Grid.Row="0" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
                    <TextBlock x:Name="Pane0Header" Style="{StaticResource PaneHeaderText}"/>
                </Border>
                <controls:TerminalHost Grid.Row="1" x:Name="Terminal0"/>
            </Grid>

            <GridSplitter x:Name="VSplitter" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                          Width="3" Background="#3d3d3d" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"/>

            <Grid x:Name="Pane1Container" Grid.Row="0" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
                    <TextBlock x:Name="Pane1Header" Style="{StaticResource PaneHeaderText}"/>
                </Border>
                <controls:TerminalHost Grid.Row="1" x:Name="Terminal1"/>
            </Grid>

            <GridSplitter x:Name="HSplitter" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                          Height="3" Background="#3d3d3d" VerticalAlignment="Center"
                          HorizontalAlignment="Stretch"/>

            <Grid x:Name="Pane2Container" Grid.Row="2" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
                    <TextBlock x:Name="Pane2Header" Style="{StaticResource PaneHeaderText}"/>
                </Border>
                <controls:TerminalHost Grid.Row="1" x:Name="Terminal2"/>
            </Grid>

            <Grid x:Name="Pane3Container" Grid.Row="2" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
                    <TextBlock x:Name="Pane3Header" Style="{StaticResource PaneHeaderText}"/>
                </Border>
                <controls:TerminalHost Grid.Row="1" x:Name="Terminal3"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
