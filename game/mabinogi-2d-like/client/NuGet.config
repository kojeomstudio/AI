<?xml version="1.0" encoding="utf-8"?>
<!-- Godot.NET.Sdk / GodotSharp 4.6.3은 프리빌트 에디터에 동봉된 로컬 nupkg에서 가져온다.
     MessagePack 등 나머지는 nuget.org. -->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
