<Window x:Class="ExcelToJsonExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel to JSON Exporter" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="700" MinHeight="450">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding BrowseInputCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportCommand}"/>
    </Window.InputBindings>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="입력/출력 설정" Margin="0,0,0,8" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="엑셀 파일:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" Margin="0,0,8,4" VerticalAlignment="Center"/>
                <Button Grid.Row="0" Grid.Column="2" Content="찾아보기..." Command="{Binding BrowseInputCommand}"
                        Width="80" Margin="0,0,0,4" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="출력 폴더:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" Margin="0,4,8,0" VerticalAlignment="Center"/>
                <Button Grid.Row="1" Grid.Column="2" Content="찾아보기..." Command="{Binding BrowseOutputCommand}"
                        Width="80" Margin="0,4,0,0" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="시트 선택" Margin="0,0,0,8" Padding="4">
            <ListBox x:Name="SheetListBox" ItemsSource="{Binding Sheets}" SelectedItem="{Binding SelectedSheet}"
                     DisplayMemberPath="SheetName" Height="80" FontSize="13">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </GroupBox>

        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                       x:Name="StatusText" Text="시트를 선택하면 데이터 미리보기가 표시됩니다." Foreground="Gray"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="JSON 내보내기 (Ctrl+E)" Command="{Binding ExportCommand}"
                        Padding="16,6" FontWeight="Bold" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="PreviewDataGrid" Grid.Row="3"
                  AutoGenerateColumns="True" IsReadOnly="True"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  FontFamily="Consolas" FontSize="12"
                  AlternatingRowBackground="#F5F5F5"/>

        <GroupBox Grid.Row="4" Header="로그" Margin="0,8,0,0" Padding="4">
            <ListBox ItemsSource="{Binding LogMessages}" Height="100"
                     FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>
    </Grid>
</Window>
