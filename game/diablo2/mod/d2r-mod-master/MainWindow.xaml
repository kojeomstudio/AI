<Window x:Class="D2RModMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Version, StringFormat='D2R Mod Master {0}'}" 
        Height="750" Width="1100" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section 1: Configuration -->
        <GroupBox Header="CASC Configuration" Margin="0,0,0,10" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <DockPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock DockPanel.Dock="Top" Text="D2R Installation Path" FontSize="10" Foreground="Gray" Margin="2,0,0,2"/>
                    <Button DockPanel.Dock="Right" Content="Browse..." Command="{Binding BrowseCommand}" Width="75" Height="26" Margin="5,0,0,0"/>
                    <TextBox Text="{Binding D2RPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="3" Height="26"/>
                </DockPanel>
                
                <DockPanel Grid.Column="2" Margin="10,0,5,0">
                    <TextBlock DockPanel.Dock="Top" Text="Search Mask" FontSize="10" Foreground="Gray" Margin="2,0,0,2"/>
                    <TextBox Text="{Binding SearchMask, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="3" Height="26"/>
                </DockPanel>
                
                <Button Grid.Column="3" Content="Load Storage" Command="{Binding LoadCommand}" Width="120" Height="26" VerticalAlignment="Bottom" FontWeight="Bold" Margin="5,0,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Section 2: Main Explorer -->
        <TabControl Grid.Row="1" Margin="0,0,0,5">
            <TabItem Header="CASC Explorer">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TreeView -->
                    <TreeView x:Name="CascTreeView" ItemsSource="{Binding CascNodes}" Grid.Column="0" SelectedItemChanged="CascTreeView_SelectedItemChanged"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling" BorderBrush="LightGray">
                        <TreeView.Resources>
                            <ContextMenu x:Key="ItemContextMenu">
                                <MenuItem Header="Extract File/Folder" Command="{Binding DataContext.ExtractCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Separator/>
                                <MenuItem Header="Copy Virtual Path" Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </ContextMenu>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Foreground="Gray" Width="45" Margin="0,0,5,0" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

                    <!-- Details Pane -->
                    <Border Grid.Column="2" Margin="10,0,0,0" Padding="10" Background="#F9F9F9" BorderBrush="LightGray" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel Visibility="{Binding CanExtract, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Asset Details" FontWeight="Bold" FontSize="15" Margin="0,0,0,12" Foreground="#2D72BC"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource DetailLabelStyle}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNode.Name}" Style="{StaticResource DetailValueStyle}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" Style="{StaticResource DetailLabelStyle}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNode.Size}" Style="{StaticResource DetailValueStyle}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" Style="{StaticResource DetailLabelStyle}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNode.Type}" Style="{StaticResource DetailValueStyle}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Path:" Style="{StaticResource DetailLabelStyle}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNode.FullPath}" Style="{StaticResource DetailValueStyle}" FontSize="10" Opacity="0.8"/>
                                    </Grid>

                                    <Separator Margin="0,15"/>
                                    
                                    <CheckBox Content="Preserve Hierarchy on Extract" IsChecked="{Binding UseHierarchy}" Margin="0,0,0,10" ToolTip="If checked, recreating full folder structure in destination."/>
                                    <Button Content="Export Selected Asset" Command="{Binding ExtractCommand}" Height="35" FontWeight="Bold" Background="#E1F5FE" BorderBrush="#2D72BC"/>
                                    <TextBlock Text="* Folders are extracted recursively." FontSize="10" Foreground="Gray" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="Select a file or folder to see details" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" FontStyle="Italic"
                                           Visibility="{Binding CanExtract, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <!-- Loading Overlay -->
                    <Grid Grid.ColumnSpan="3" Background="#AAFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="250" Height="10"/>
                            <TextBlock Text="{Binding LoadingStage}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Bold" Foreground="#2D72BC"/>
                            <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
            
            <TabItem Header="Asset Preview">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <Button Content="Copy Content to Clipboard" Command="{Binding CopyPreviewCommand}" DockPanel.Dock="Right" Padding="12,5" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Previewing: " FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text="{Binding SelectedNode.FullPath}" Foreground="#2D72BC" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBox Grid.Row="1" Text="{Binding PreviewText}" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" 
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                             FontFamily="Consolas" Background="#F8F8F8" BorderThickness="1" BorderBrush="#E0E0E0" Padding="10"/>
                </Grid>
            </TabItem>

            <TabItem Header="Mod Management">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                            <TextBlock Text="D2R Mod Structure Generator" FontSize="22" FontWeight="Bold" Foreground="#2D72BC" Margin="0,0,0,10"/>
                            <TextBlock Text="이 도구는 디아블로 2 레저렉션 모딩에 필요한 표준 폴더 구조와 modinfo.json 파일을 자동으로 생성합니다." TextWrapping="Wrap" Margin="0,0,0,25" Foreground="DimGray" FontSize="13"/>
                            
                            <GroupBox Header="Mod Configuration" Padding="20" BorderBrush="#E0E0E0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,20">
                                        <TextBlock Text="Mod Name" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding ModName, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,20">
                                        <TextBlock Text="Save Path (Optional)" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding ModSavePath, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                                        <TextBlock Text="* 기본값 '../'은 공통 세이브 폴더를 사용함을 의미합니다." FontSize="10" Foreground="Gray" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Row="1" Grid.ColumnSpan="2" Content="Generate Mod Structure &amp; modinfo.json" Command="{Binding CreateModInfoCommand}" 
                                            Height="50" FontWeight="Bold" FontSize="15" Background="#E8F5E9" BorderBrush="#4CAF50" Cursor="Hand"/>
                                </Grid>
                            </GroupBox>
                            
                            <Border Margin="0,30,0,0" Padding="20" Background="#FFF9C4" CornerRadius="5" BorderBrush="#FBC02D" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="How to use:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#A44000"/>
                                    <TextBlock Text="1. 모드 이름을 입력하고 생성 버튼을 누릅니다.&#x0a;2. D2R이 설치된 루트 폴더를 선택합니다. (예: C:\Program Files (x86)\Diablo II Resurrected)&#x0a;3. 자동으로 mods/ 폴더 아래에 필요한 구조가 생성됩니다.&#x0a;4. 'CASC Explorer' 탭에서 추출한 파일들을 생성된 data 폴더에 넣으세요." Foreground="#5D4037" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Section 3: Logs -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Margin="0,2"/>

        <GroupBox Grid.Row="3">
            <GroupBox.Header>
                <DockPanel LastChildFill="False" Width="Auto">
                    <TextBlock Text="Activity Logs" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Button Content="Open Log Folder" Command="{Binding OpenLogFolderCommand}" Padding="8,2" FontSize="11" Margin="0,0,8,0"/>
                    <Button Content="Clear" Command="{Binding ClearLogsCommand}" Padding="12,2" FontSize="11"/>
                </DockPanel>
            </GroupBox.Header>
            <ListBox ItemsSource="{Binding Logs}" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="#FDFDFD">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" FontSize="11" FontFamily="Consolas" Margin="0,1">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                            <Setter Property="Foreground" Value="#F57C00"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Section 4: Status Bar -->
        <StatusBar Grid.Row="4" Margin="0,5,-12,-12" Background="#EEEEEE" BorderBrush="LightGray" BorderThickness="0,1,0,0">
            <StatusBarItem Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status: " Foreground="Gray" FontWeight="Medium"/>
                    <TextBlock Text="{Binding StatusText}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total Assets Mapped: " Foreground="Gray" FontWeight="Medium"/>
                    <TextBlock Text="{Binding CurrentFiles, StringFormat='{}{0:N0}'}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
