<Window x:Class="D2RModMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Version, StringFormat='D2R Mod Master {0}'}" Height="700" Width="1000">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="Width" Value="80"/>
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,0,0,5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section 1: Configuration -->
        <GroupBox Header="CASC Configuration" Margin="0,0,0,10" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="D2R Installation Path" FontSize="10" Foreground="Gray" Margin="2,0,0,2"/>
                    <TextBox Text="{Binding D2RPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="3"/>
                </StackPanel>
                
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseCommand}" Width="75" Height="26" VerticalAlignment="Bottom" Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="2" Margin="0,0,5,0">
                    <TextBlock Text="Search Mask" FontSize="10" Foreground="Gray" Margin="2,0,0,2"/>
                    <TextBox Text="{Binding SearchMask, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="3"/>
                </StackPanel>
                
                <Button Grid.Column="3" Content="Load Storage" Command="{Binding LoadCommand}" Width="100" Height="26" VerticalAlignment="Bottom" FontWeight="Bold"/>
            </Grid>
        </GroupBox>

        <!-- Section 2: Main Explorer -->
        <TabControl Grid.Row="1" Margin="0,0,0,5">
            <TabItem Header="CASC Explorer">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TreeView -->
                    <TreeView x:Name="CascTreeView" ItemsSource="{Binding CascNodes}" Grid.Column="0" SelectedItemChanged="CascTreeView_SelectedItemChanged"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling" BorderBrush="LightGray">
                        <TreeView.Resources>
                            <ContextMenu x:Key="ItemContextMenu">
                                <MenuItem Header="Extract File/Folder" Command="{Binding DataContext.ExtractCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Separator/>
                                <MenuItem Header="Copy Virtual Path" Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </ContextMenu>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" Foreground="Gray" Width="45" Margin="0,0,5,0" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

                    <!-- Details Pane -->
                    <Border Grid.Column="2" Margin="10,0,0,0" Padding="10" Background="#F9F9F9" BorderBrush="LightGray" BorderThickness="1" CornerRadius="3">
                        <Grid>
                            <StackPanel Visibility="{Binding CanExtract, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Asset Details" FontWeight="Bold" FontSize="15" Margin="0,0,0,12" Foreground="#2D72BC"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Style="{StaticResource DetailLabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNode.Name}" Style="{StaticResource DetailValueStyle}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" Style="{StaticResource DetailLabelStyle}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNode.Size}" Style="{StaticResource DetailValueStyle}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" Style="{StaticResource DetailLabelStyle}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNode.Type}" Style="{StaticResource DetailValueStyle}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Path:" Style="{StaticResource DetailLabelStyle}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNode.FullPath}" Style="{StaticResource DetailValueStyle}" FontSize="10"/>
                                </Grid>

                                <Separator Margin="0,15"/>
                                
                                <CheckBox Content="Preserve Hierarchy on Extract" IsChecked="{Binding UseHierarchy}" Margin="0,0,0,10" ToolTip="If checked, recreating full folder structure in destination."/>
                                <Button Content="Export Selected Asset" Command="{Binding ExtractCommand}" Height="35" FontWeight="Bold" Background="#E1F5FE" BorderBrush="#2D72BC"/>
                                <TextBlock Text="* Folders are extracted recursively." FontSize="10" Foreground="Gray" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="Select a file or folder to see details" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" FontStyle="Italic"
                                       Visibility="{Binding CanExtract, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </Grid>
                    </Border>

                    <!-- Loading Overlay -->
                    <Grid Grid.ColumnSpan="3" Background="#AAFFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="250" Height="10"/>
                            <TextBlock Text="{Binding LoadingStage}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="Bold" Foreground="#2D72BC"/>
                            <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
            
            <TabItem Header="Asset Preview">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <Button Content="Copy Content to Clipboard" Command="{Binding CopyPreviewCommand}" DockPanel.Dock="Right" Padding="10,5"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Previewing: " FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text="{Binding SelectedNode.FullPath}" Foreground="#2D72BC" TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBox Grid.Row="1" Text="{Binding PreviewText}" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" 
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                             FontFamily="Consolas" Background="#F0F0F0" BorderThickness="0" Padding="5"/>
                </Grid>
            </TabItem>

            <TabItem Header="Mod Management">
                <Grid Margin="20">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="D2R Mod Structure Generator" FontSize="20" FontWeight="Bold" Foreground="#2D72BC" Margin="0,0,0,20"/>
                        <TextBlock Text="이 도구는 디아블로 2 레저렉션 모딩에 필요한 표준 폴더 구조와 modinfo.json 파일을 자동으로 생성합니다." TextWrapping="Wrap" Margin="0,0,0,20" Foreground="DimGray"/>
                        
                        <GroupBox Header="Mod Configuration" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Mod Name" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ModName, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,15"/>
                                
                                <TextBlock Text="Save Path (Optional)" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ModSavePath, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,5"/>
                                <TextBlock Text="* 이 설정을 통해 모드 전용 세이브 폴더를 분리할 수 있습니다." FontSize="10" Foreground="Gray" Margin="0,0,0,20"/>
                                
                                <Button Content="Generate Mod Structure &amp; modinfo.json" Command="{Binding CreateModInfoCommand}" Height="40" FontWeight="Bold" Background="#E8F5E9" BorderBrush="#4CAF50"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <TextBlock Text="How to use:" FontWeight="Bold" Margin="0,25,0,10"/>
                        <TextBlock Text="1. 모드 이름을 입력하고 생성 버튼을 누릅니다.&#x0a;2. D2R이 설치된 루트 폴더를 선택합니다. (예: C:\Program Files (x86)\Diablo II Resurrected)&#x0a;3. 자동으로 mods/폴더 아래에 필요한 구조가 생성됩니다.&#x0a;4. 'CASC Explorer' 탭에서 추출한 파일들을 생성된 data 폴더에 넣으세요." Foreground="Gray" LineHeight="20"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Section 3: Logs -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Margin="0,2"/>

        <GroupBox Grid.Row="3">
            <GroupBox.Header>
                <DockPanel LastChildFill="False" Width="Auto">
                    <TextBlock Text="Activity Logs" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Button Content="Open Log Folder" Command="{Binding OpenLogFolderCommand}" Padding="8,1" FontSize="10" Margin="0,0,5,0"/>
                    <Button Content="Clear" Command="{Binding ClearLogsCommand}" Padding="12,1" FontSize="10"/>
                </DockPanel>
            </GroupBox.Header>
            <ListBox ItemsSource="{Binding Logs}" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="#FDFDFD">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayText}" FontSize="11" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- Section 4: Status Bar -->
        <StatusBar Grid.Row="4" Margin="0,5,-12,-12" Background="#F0F0F0">
            <StatusBarItem Padding="10,2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status: " Foreground="Gray"/>
                    <TextBlock Text="{Binding StatusText}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Items: " Foreground="Gray"/>
                    <TextBlock Text="{Binding CurrentFiles}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
